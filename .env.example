# Base URL of the backend API (include the /api suffix, no trailing slash).
# Local: http://localhost:4000/api
# Production: set this in the Vercel dashboard to your deployed backend.
VITE_API_URL=http://localhost:4000/api

# Printer adapter: "preview" (on-screen badges, no hardware) or "webusb" (Gainscha over WebUSB).
VITE_PRINTER_MODE=preview
